{
  "ubo_rule": {
    "threshold_percentage": 25,
    "operator": ">=",
    "description": "A UBO is a natural person who directly or indirectly owns 25% or more of the company."
  },
  "address_proof_rule": {
    "max_age_months": 3,
    "applies_to": ["director", "authorized_representative", "ubo"],
    "required": true
  },
  "standard_kyc_rules": {
    "kyc_validity_months": 6,
    "required_file_format": "pdf",
    "signed_document_requirements": ["signer_name", "signer_title", "signature_date"],
    "authorized_representative_must_sign": ["institution_onboarding_form", "mutual_nda"],
    "authorization_letter_required_even_single_director": true,
    "authorization_letter_director_signatures_required": "all_directors",
    "authorization_letter_email_must_match_kyc_form": true,
    "board_resolution_must_define_business_scope": true,
    "coi_recent_issue_months_except": {
      "max_age_months": 6,
      "excluded_jurisdictions": ["Hong Kong", "Singapore"]
    },
    "certificate_of_incumbency_max_age_months": 6,
    "certificate_of_incumbency_required_content": [
      "The Company is in existence and in good legal standing.",
      "Current Members / Directors",
      "Current Shareholders",
      "Issuer identity statement including name, firm and license number if any",
      "Issuer signature"
    ],
    "nda_validity_years": 2,
    "nda_required_file_format": "pdf",
    "nda_requires_real_signing_date": true,
    "nda_unfilled_brackets_prohibited": true,
    "nda_template_change_requires": "legal_confirmation_email",
    "nda_third_party_template_requires": "legal_and_business_confirmation_email",
    "allowed_nda_counterparties": [
      "Antalpha Digital Pte. Ltd.",
      "Northstar Digital (HK) Limited",
      "URSALPHA DIGITAL LLC"
    ],
    "ownership_chart_required_statements": [
      "I declared that this is true, accurate, and up-to-date",
      "No other natural person, whether directly or indirectly, owns 25% or more of xxx’s shares or controlling power."
    ],
    "email_sla_hours": 4,
    "email_question_ratio_max": 0.1,
    "external_date_formats": ["dd MMM yyyy", "MM/dd/yyyy"]
  },
  "jurisdiction_rules": {
    "accepted_standard": ["Hong Kong", "Singapore", "BVI", "Cayman"],
    "requires_state": ["United States"],
    "requires_legal_review": ["European countries", "Other countries"],
    "offshore": ["BVI", "Cayman", "Other offshore"],
    "prohibited": ["Mainland China"],
    "high_risk_jurisdictions": {
      "source": "compliance_maintained_list",
      "list": [],
      "default_action": "manual_review_required"
    }
  },
  "base_documents": [
    {"id":"certificate_of_incorporation","name":"Certificate of Incorporation","category":"Constitutional","required":true,"reason":"Required for all companies"},
    {"id":"certificate_of_incumbency","name":"Certificate of Incumbency","category":"Constitutional","required":true,"reason":"Must be issued within the last 6 months"},
    {"id":"business_registration_certificate","name":"Business Registration Certificate","category":"Constitutional","required":true,"reason":"Required for all companies if applicable"},
    {"id":"articles_of_association","name":"Articles of Association","category":"Constitutional","required":true,"reason":"Required for all companies"},
    {"id":"register_of_directors","name":"Register of Directors","category":"Constitutional","required":true,"reason":"Required for all companies"},
    {"id":"register_of_shareholders","name":"Register of Shareholders","category":"Constitutional","required":true,"reason":"Required for all companies"},
    {"id":"ownership_structure_chart","name":"Ownership Structure Chart","category":"Constitutional","required":true,"reason":"Required to identify UBOs"},
    {"id":"business_description","name":"Business Description","category":"Constitutional","required":true,"reason":"Required for business risk assessment"},
    {"id":"source_of_funds","name":"Source of Funds","category":"Constitutional","required":true,"reason":"Required for AML assessment"}
  ],
  "hk_specific_documents": [
    {"id":"non_us_person_non_solicitation_hk_confirmation","name":"Non-US Person & Non-solicitation in HK Confirmation","category":"HK Specific","required":true,"reason":"Required for Hong Kong registered companies"},
    {"id":"hk_nnc1_or_nar1","name":"NNC1 or NAR1","category":"HK Specific","required":true,"reason":"Hong Kong companies must provide NNC1 if incorporated within 1 year, or NAR1 if incorporated for 1 year or more"},
    {"id":"hk_nd2a_director_change","name":"ND2A Director Change Filing","category":"HK Specific","required":true,"reason":"Required for Hong Kong companies when director information has changed"}
  ],
  "company_type_documents": {
    "llc": [
      {"id":"llc_operating_agreement","name":"LLC Operating Agreement","category":"Entity Type","required":true,"reason":"Required for Limited Liability Company entities"}
    ],
    "limited_company": [
      {"id":"memorandum_of_association","name":"Memorandum of Association","category":"Entity Type","required":true,"reason":"Required for Limited / Ltd entities where applicable"}
    ],
    "corporation": [
      {"id":"corporation_bylaws","name":"Bylaws","category":"Entity Type","required":true,"reason":"Required for Corporation / Inc entities"}
    ],
    "limited_partnership": [
      {"id":"limited_partnership_agreement","name":"Limited Partnership Agreement","category":"Entity Type","required":true,"reason":"Required for Limited Partnership entities"},
      {"id":"investment_manager_advisor_agreement","name":"Investment Manager / Advisor Agreement","category":"Entity Type","required":true,"reason":"Required for Limited Partnership / fund structures"},
      {"id":"administrator_agreement","name":"Administrator Agreement","category":"Entity Type","required":true,"reason":"Required for Limited Partnership / fund structures"}
    ],
    "trust": [
      {"id":"trust_deed","name":"Trust Deed","category":"Entity Type","required":true,"reason":"Required for trust entities; must identify trust name, beneficiaries/classes, settlor, trustee, protector/executor and controllers"}
    ],
    "spc_fund": [
      {"id":"fund_certificate_of_incumbency","name":"Fund Certificate of Incumbency","category":"Entity Type","required":true,"reason":"Required for SPC fund structures"},
      {"id":"fund_management_agreement","name":"Fund Management Agreement","category":"Entity Type","required":true,"reason":"Required for SPC fund structures"},
      {"id":"investment_manager_advisor_agreement","name":"Investment Manager / Advisor Agreement","category":"Entity Type","required":true,"reason":"Required for SPC fund structures"},
      {"id":"administrator_agreement","name":"Administrator Agreement","category":"Entity Type","required":true,"reason":"Required for SPC fund structures"}
    ],
    "name_change": [
      {"id":"certificate_of_change_of_name","name":"Certificate of Change of Name","category":"Entity Type","required":true,"reason":"Required if any submitted document indicates a company name change"}
    ]
  },
  "internal_forms": [
    {"id":"institution_onboarding_form","name":"Institution Onboarding Form","category":"Internal Form","required":true,"reason":"Required internal onboarding form"},
    {"id":"authorization_letter","name":"Authorization Letter","category":"Internal Form","required":true,"reason":"Required to verify authorized representative"},
    {"id":"mutual_nda","name":"Mutual NDA","category":"Internal Form","required":true,"reason":"Required internal form"},
    {"id":"board_resolution","name":"Board Resolution","category":"Internal Form","required":true,"reason":"Required to authorize account opening and signatories"},
    {"id":"declaration_source_of_fund_wealth","name":"Declaration of Source of Fund/Wealth","category":"Internal Form","required":true,"reason":"Required source of fund/wealth declaration"}
  ],
  "us_state_rules": {
    "Delaware": [
      {"id":"us_de_formation_or_incorporation","name":"Formation / Incorporation Document","category":"US State Specific","required":true,"reason":"Required for Delaware entities"},
      {"id":"us_de_good_standing","name":"Good Standing Certificate","category":"US State Specific","required":true,"reason":"Delaware Good Standing must be issued within the last 6 months"},
      {"id":"us_de_operating_agreement_or_bylaws","name":"Operating Agreement / Bylaws","category":"US State Specific","required":true,"reason":"Required for Delaware entities"},
      {"id":"us_de_ein_confirmation_letter","name":"EIN Confirmation Letter","category":"US State Specific","required":true,"reason":"Required for Delaware entities"}
    ],
    "Wyoming": [
      {"id":"us_wy_articles","name":"Articles","category":"US State Specific","required":true,"reason":"Required for Wyoming entities"},
      {"id":"us_wy_good_standing","name":"Good Standing Certificate","category":"US State Specific","required":true,"reason":"Required for Wyoming entities"},
      {"id":"us_wy_operating_agreement","name":"Operating Agreement","category":"US State Specific","required":true,"reason":"Required for Wyoming entities"},
      {"id":"us_wy_ein_confirmation_letter","name":"EIN Confirmation Letter","category":"US State Specific","required":true,"reason":"Required for Wyoming entities"},
      {"id":"us_wy_certificate_of_incumbency","name":"Certificate of Incumbency","category":"US State Specific","required":true,"reason":"Required for Wyoming entities"},
      {"id":"us_wy_county_clerk_check","name":"County Clerk Search Evidence","category":"US State Specific","required":true,"reason":"Wyoming has limited public records; County Clerk search is required"}
    ],
    "Nevada": [
      {"id":"us_nv_articles","name":"Articles","category":"US State Specific","required":true,"reason":"Required for Nevada entities"},
      {"id":"us_nv_certificate_of_existence","name":"Certificate of Existence","category":"US State Specific","required":true,"reason":"Required for Nevada entities"},
      {"id":"us_nv_business_license","name":"Nevada State Business License","category":"US State Specific","required":true,"reason":"Required for Nevada entities"},
      {"id":"us_nv_operating_agreement","name":"Operating Agreement","category":"US State Specific","required":true,"reason":"Required for Nevada entities"}
    ],
    "California": [
      {"id":"us_ca_articles","name":"Articles","category":"US State Specific","required":true,"reason":"Required for California entities"},
      {"id":"us_ca_statement_of_information","name":"Statement of Information (Form SI-550)","category":"US State Specific","required":true,"reason":"Required for California entities"},
      {"id":"us_ca_ein_confirmation_letter","name":"EIN Confirmation Letter","category":"US State Specific","required":true,"reason":"Required for California entities"}
    ],
    "Texas": [
      {"id":"us_tx_certificate_of_formation","name":"Certificate of Formation","category":"US State Specific","required":true,"reason":"Required for Texas entities"},
      {"id":"us_tx_certificate_of_fact_status","name":"Certificate of Fact - Status","category":"US State Specific","required":true,"reason":"Texas equivalent of Good Standing"},
      {"id":"us_tx_operating_agreement","name":"Operating Agreement","category":"US State Specific","required":true,"reason":"Required for Texas entities"},
      {"id":"us_tx_ein_confirmation_letter","name":"EIN Confirmation Letter","category":"US State Specific","required":true,"reason":"Required for Texas entities"}
    ],
    "New York": [
      {"id":"us_ny_publication_proof","name":"Publication Proof for LLC","category":"US State Specific","required":true,"reason":"Required for New York LLC onboarding review"}
    ],
    "Washington D.C.": [
      {"id":"us_dc_basic_business_license","name":"Basic Business License","category":"US State Specific","required":true,"reason":"Required due to Washington D.C. local BSA controls"}
    ]
  },
  "risk_based_documents": {
    "financial_or_user_asset_manager": [
      {"id":"aml_questionnaire","name":"AML / Wolfsberg Questionnaire","category":"Risk Based","required":true,"reason":"Required for licensed financial institutions or entities managing user/client assets or investing on behalf of clients"},
      {"id":"letter_of_undertaking","name":"Letter of Undertaking","category":"Risk Based","required":true,"reason":"Required for licensed financial institutions or entities managing user/client assets"}
    ],
    "entity_shareholder": [
      {"id":"ubo_no_other_shareholder_declaration","name":"UBO No Other Shareholder Declaration","category":"Risk Based","required":true,"reason":"Required when ownership structure cannot be fully traced to UBOs with >=25% beneficial ownership"}
    ],
    "worldcheck_alert": [
      {"id":"ncrs_pep_form","name":"NCRS & PEP Form","category":"Risk Based","required":true,"reason":"Required when Worldcheck alert indicates no prior NCRS & PEP form on file"},
      {"id":"worldcheck_news_explanation","name":"Worldcheck Alert News Explanation","category":"Risk Based","required":true,"reason":"Required when prior NCRS & PEP form exists and a new Worldcheck news alert needs explanation"}
    ],
    "high_risk_customer": [
      {"id":"initial_source_of_funds_evidence","name":"Initial Source of Funds Evidence","category":"Risk Based","required":true,"reason":"Required for high-risk customers"},
      {"id":"ongoing_source_of_funds_evidence","name":"Ongoing Source of Funds Evidence","category":"Risk Based","required":true,"reason":"Required for high-risk customers"},
      {"id":"initial_and_ongoing_sof_explanation","name":"Initial and Ongoing Source of Funds Explanation Email","category":"Risk Based","required":true,"reason":"Required for high-risk customers"},
      {"id":"associated_individual_background_profile","name":"Associated Individual Background Profile","category":"Risk Based","required":true,"reason":"High-risk customers must provide background information for associated individuals, including education and industry experience"}
    ]
  },
  "associated_individual_documents": {
    "roles": ["director", "authorized_representative", "ubo"],
    "documents": [
      {"id":"online_identity_verification","name":"Online Identity Verification / Au10tix","category":"Individual","required":true,"reason":"Required when passport / ID is not certified true copy, or where online identity verification is required"},
      {"id":"passport_or_id","name":"Certified Passport / Accepted National ID","category":"Individual","required":true,"reason":"All Director, AR and UBO must provide certified passport or accepted national ID, including HK PR ID, Singapore PR ID, or China ID"},
      {"id":"proof_of_current_residential_address","name":"Proof of Current Residential Address","category":"Individual","required":true,"reason":"Must be issued within the last 3 months"}
    ]
  },
  "crypto_business_rules": {
    "source_of_crypto_assets_required": true,
    "wallet_address_list_required": false,
    "wallet_address_list_policy": "request_if_available_or_if_needed_for_chain_risk_review",
    "alternative_evidence_accepted": ["exchange_statement", "custodian_statement", "transaction_history", "audited_financial_statement", "bank_statement", "financing_agreement", "mining_pool_evidence"],
    "missing_evidence_issue": "missing_source_of_funds_evidence",
    "documents": [
      {"id":"source_of_crypto_assets","name":"Source of Crypto Assets / Supporting Evidence","category":"Crypto Extra","required":true,"reason":"Required for crypto-related businesses"},
      {"id":"aml_questionnaire","name":"AML Questionnaire","category":"Risk Based","required":true,"reason":"Required for crypto-related businesses"},
      {"id":"wallet_address_list","name":"Other Documents, if available","category":"Crypto Extra","required":false,"reason":"Optional slot for additional helpful documents, including wallet address lists if available or requested for chain risk review"}
    ]
  },
  "mining_business_rules": {
    "mining_proof_required": true,
    "accepted_mining_proof": ["antpool_observer_link", "mining_pool_observer_link", "mining_pool_account_evidence", "mining_revenue_record"],
    "wallet_receiving_mining_proceeds_required": false,
    "wallet_policy": "request_if_available",
    "documents": [
      {"id":"mining_proof","name":"Mining Proof, e.g. Antpool Observer Link","category":"Mining Extra","required":true,"reason":"Required for mining businesses"},
      {"id":"mining_revenue_evidence","name":"Mining Revenue Evidence","category":"Mining Extra","required":false,"reason":"Recommended evidence for mining businesses"},
      {"id":"mining_wallet_address","name":"Wallet Receiving Mining Proceeds, if available","category":"Mining Extra","required":false,"reason":"Request if available"}
    ]
  },
  "financing_source_rules": {
    "required_documents": [
      {"id":"financing_agreement","name":"Financing Agreement","category":"Financing Extra","required":true,"reason":"Required when source of funds is financing"},
      {"id":"investor_lender_information","name":"Investor / Lender Information","category":"Financing Extra","required":true,"reason":"Required when source of funds is financing"},
      {"id":"proof_of_fund_transfer","name":"Proof of Fund Transfer","category":"Financing Extra","required":true,"reason":"Required to evidence movement of funds"}
    ],
    "supporting_documents": ["bank_statement", "wallet_transaction_evidence", "board_approval", "use_of_proceeds_explanation"]
  }
}
